<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Test_Account_Update</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISNEW()),
    ISCHANGED(Test_Account__c)
)</errorConditionFormula>
    <errorDisplayField>Test_Account__c</errorDisplayField>
    <errorMessage>The Test Account field cannot be modified after the account is created.</errorMessage>
</ValidationRule>